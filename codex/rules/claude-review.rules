prefix_rule(
    pattern = ["claude", "-p", "--permission-mode", "plan", "--output-format", "text"],
    decision = "allow",
    justification = "Claude-backed Codex reviews are explicitly authorized to read repository context",
    match = [
        "claude -p --permission-mode plan --output-format text review",
    ],
    not_match = [
        "claude -p review",
        "claude --permission-mode plan --output-format text review",
    ],
)

prefix_rule(
    pattern = ["env", "-u", "PYTHONPATH", "-u", "VIRTUAL_ENV", "claude", "-p", "--permission-mode", "plan", "--output-format", "text"],
    decision = "allow",
    justification = "Claude-backed Codex code reviews need the worktree environment isolated",
    match = [
        "env -u PYTHONPATH -u VIRTUAL_ENV claude -p --permission-mode plan --output-format text review",
    ],
    not_match = [
        "env -u PYTHONPATH claude -p --permission-mode plan --output-format text review",
        "env -u PYTHONPATH -u VIRTUAL_ENV claude -p review",
    ],
)
