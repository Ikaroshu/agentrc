        "omp --profile review -p --no-session --no-extensions --no-skills --no-rules --no-lsp --tools read,grep,glob --approval-mode always-ask --model openrouter/x-ai/grok-4.5 review",
    ],
    not_match = [
        "omp --profile review -p --no-session --no-extensions --no-skills --no-rules --no-lsp --tools read,grep,glob,edit --approval-mode always-ask --model openrouter/x-ai/grok-4.5 review",
        "omp --profile review -p --no-session --model openrouter/x-ai/grok-4.5 review",
    ],
)

