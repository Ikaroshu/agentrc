prefix_rule(
    pattern = ["omp", "--profile", "review", "-p", "--no-session", "--no-extensions", "--no-skills", "--no-rules", "--no-lsp", "--tools", "read,grep,glob", "--approval-mode", "always-ask", "--model", "pareto-easy/openrouter/pareto-code"],
    decision = "allow",
    justification = "User explicitly authorizes the isolated read-only OMP review profile to transmit supplied repository documents and diffs through OpenRouter and its selected model provider",
    match = [
        "omp --profile review -p --no-session --no-extensions --no-skills --no-rules --no-lsp --tools read,grep,glob --approval-mode always-ask --model pareto-easy/openrouter/pareto-code review",
    ],
    not_match = [
        "omp --profile review -p --no-session --no-extensions --no-skills --no-rules --no-lsp --tools read,grep,glob,bash --approval-mode always-ask --model pareto-easy/openrouter/pareto-code review",
        "omp --profile review -p --no-session --model pareto-easy/openrouter/pareto-code review",
    ],
)
prefix_rule(
    pattern = ["omp", "--profile", "review", "-p", "--no-session", "--no-extensions", "--no-skills", "--no-rules", "--no-lsp", "--tools", "read,grep,glob", "--approval-mode", "always-ask", "--model", "pareto-medium/openrouter/pareto-code"],
    decision = "allow",
    justification = "User explicitly authorizes the isolated read-only OMP review profile to transmit supplied repository documents and diffs through OpenRouter and its selected model provider",
    match = [
        "omp --profile review -p --no-session --no-extensions --no-skills --no-rules --no-lsp --tools read,grep,glob --approval-mode always-ask --model pareto-medium/openrouter/pareto-code review",
    ],
    not_match = [
        "omp --profile review -p --no-session --no-extensions --no-skills --no-rules --no-lsp --tools read,grep,glob,edit --approval-mode always-ask --model pareto-medium/openrouter/pareto-code review",
        "omp --profile review -p --no-session --model pareto-medium/openrouter/pareto-code review",
    ],
)

